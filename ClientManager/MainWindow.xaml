<Window x:Class="ClientManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Учёт клиентов" Height="650" Width="1050"
        WindowStartupLocation="CenterScreen"
        Background="#F0F2F5"
        Loaded="Window_Loaded">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#2C3E50" Padding="12">
            <Grid>
                <TextBlock Text="Учёт клиентов" FontSize="20" FontWeight="Bold" Foreground="White"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock x:Name="TotalCountText" Text="Клиентов: 0" Foreground="#BDC3C7" FontSize="12" Margin="0,0,15,0" VerticalAlignment="Center"/>
                    <Button Content="Обновить" Width="100" Height="28" Background="#3498DB" Foreground="White" BorderThickness="0" Click="RefreshButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="350"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" CornerRadius="5" Padding="12" BorderBrush="#E0E0E0" BorderThickness="1">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Карточка клиента" FontSize="15" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,10"/>

                        <TextBlock Text="ФИО *" FontSize="12" Foreground="#777" Margin="0,0,0,2"/>
                        <TextBox x:Name="FullNameTextBox" Height="28" FontSize="13" Margin="0,0,0,8"/>

                        <TextBlock Text="Телефон" FontSize="12" Foreground="#777" Margin="0,0,0,2"/>
                        <TextBox x:Name="PhoneTextBox" Height="28" FontSize="13" Margin="0,0,0,8"/>

                        <TextBlock Text="Email" FontSize="12" Foreground="#777" Margin="0,0,0,2"/>
                        <TextBox x:Name="EmailTextBox" Height="28" FontSize="13" Margin="0,0,0,8"/>


                        <TextBlock Text="Категория" FontSize="12" Foreground="#777" Margin="0,0,0,2"/>
                        <ComboBox x:Name="CategoryComboBox" Height="28" FontSize="13" Margin="0,0,0,8" IsEditable="True"/>


                        <TextBlock Text="Дата регистрации" FontSize="12" Foreground="#777" Margin="0,0,0,2"/>
                        <DatePicker x:Name="RegistrationDatePicker" Height="28" FontSize="13" Margin="0,0,0,8"/>


                        <CheckBox x:Name="IsActiveCheckBox" Content="Активен" FontSize="13" Margin="0,0,0,8" IsChecked="True"/>


                        <TextBlock Text="Заметки" FontSize="12" Foreground="#777" Margin="0,0,0,2"/>
                        <TextBox x:Name="NotesTextBox" Height="50" FontSize="13" TextWrapping="Wrap" Margin="0,0,0,10"/>


                        <WrapPanel Margin="0,0,0,10">
                            <Button Content="Добавить" Width="90" Height="30" Background="#27AE60" Foreground="White" BorderThickness="0" Margin="0,0,5,5" Click="AddButton_Click"/>
                            <Button Content="Изменить" Width="90" Height="30" Background="#2980B9" Foreground="White" BorderThickness="0" Margin="0,0,5,5" Click="UpdateButton_Click"/>
                            <Button Content="Удалить" Width="90" Height="30" Background="#E74C3C" Foreground="White" BorderThickness="0" Margin="0,0,5,5" Click="DeleteButton_Click"/>
                            <Button Content="Очистить" Width="90" Height="30" Background="#95A5A6" Foreground="White" BorderThickness="0" Margin="0,0,5,5" Click="ClearButton_Click"/>
                        </WrapPanel>

                        <Separator Margin="0,5"/>


                        <TextBlock Text="Фильтры" FontSize="14" FontWeight="Bold" Foreground="#2C3E50" Margin="0,5,0,5"/>

                        <TextBlock Text="Категория" FontSize="11" Foreground="#777"/>
                        <ComboBox x:Name="FilterCategory" Height="26" FontSize="12" Margin="0,0,0,5"/>

                        <TextBlock Text="Активность" FontSize="11" Foreground="#777"/>
                        <ComboBox x:Name="FilterActive" Height="26" FontSize="12" Margin="0,0,0,5"
                                  SelectedIndex="0">
                            <ComboBoxItem Content="Все"/>
                            <ComboBoxItem Content="Активные"/>
                            <ComboBoxItem Content="Неактивные"/>
                        </ComboBox>

                        <Button Content="Применить фильтр" Height="30" Background="#8E44AD" Foreground="White" BorderThickness="0" Margin="0,5,0,0" Click="ApplyFilterButton_Click"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <GridSplitter Grid.Column="1" Width="5" Background="Transparent"/>


            <Border Grid.Column="2" Background="White" CornerRadius="5" Padding="12" BorderBrush="#E0E0E0" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>


                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBox x:Name="SearchTextBox" Height="28" Width="200" FontSize="12" Margin="0,0,5,0"/>
                        <Button Content="Искать" Width="80" Height="28" Background="#2196F3" Foreground="White" BorderThickness="0" Click="SearchButton_Click"/>
                        <Button Content="Сброс" Width="80" Height="28" Background="#95A5A6" Foreground="White" BorderThickness="0" Margin="5,0,0,0" Click="ResetSearchButton_Click"/>
                    </StackPanel>


                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Сортировка:" VerticalAlignment="Center" FontSize="12" Margin="0,0,5,0"/>
                        <ComboBox x:Name="SortComboBox" Height="26" Width="120" FontSize="12" 
                                  SelectedIndex="0" SelectionChanged="SortComboBox_SelectionChanged">
                            <ComboBoxItem Content="По ID"/>
                            <ComboBoxItem Content="Имя"/>
                            <ComboBoxItem Content="Дата"/>
                            <ComboBoxItem Content="Категория"/>
                        </ComboBox>
                    </StackPanel>


                    <DataGrid Grid.Row="2" x:Name="ClientsDataGrid" 
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              FontSize="12"
                              RowHeight="26"
                              AlternatingRowBackground="#F8F9FA"
                              CanUserAddRows="False"


CanUserDeleteRows="False"
                              SelectionChanged="ClientsDataGrid_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="35"/>
                            <DataGridTextColumn Header="ФИО" Binding="{Binding FullName}" Width="180"/>
                            <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="120"/>
                            <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="160"/>
                            <DataGridTextColumn Header="Категория" Binding="{Binding Category}" Width="90"/>
                            <DataGridTextColumn Header="Дата" Binding="{Binding RegistrationDate, StringFormat=dd.MM.yyyy}" Width="90"/>
                            <DataGridTextColumn Header="Статус" Width="80">
                                <DataGridTextColumn.Binding>
                                    <Binding Path="IsActive"/>
                                </DataGridTextColumn.Binding>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>


        <Border Grid.Row="2" Background="#2C3E50" Padding="8">
            <TextBlock x:Name="ClockText" Text="" Foreground="#BDC3C7" FontSize="11" HorizontalAlignment="Center"/>
        </Border>
    </Grid>
</Window>